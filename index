<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>¿Qué Cultura Organizacional Eres?</title>
    <style>
        :root {
            --primary: #c62828;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: linear-gradient(135deg, #0f172a, #1e3a8a);
            min-height: 100vh;
            padding: 15px;
        }

        .container {
            max-width: 860px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        header {
            background: linear-gradient(135deg, var(--primary), #e53935);
            color: white;
            padding: 35px 20px;
            text-align: center;
        }

        .logo {
            max-width: 170px;
            margin-bottom: 12px;
        }

        h1 {
            font-size: 2.1em;
            margin-bottom: 8px;
        }

        .subtitle {
            font-size: 1.15em;
            opacity: 0.9;
        }

        .content {
            padding: 30px 20px;
        }

        .progress {
            height: 6px;
            background: #e0e0e0;
            border-radius: 10px;
            margin-bottom: 25px;
            overflow: hidden;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(to right, #c62828, #ef5350);
            width: 0%;
            transition: width 0.4s;
        }

        #question-text {
            font-size: 1.45em;
            font-weight: 600;
            margin-bottom: 25px;
            text-align: center;
        }

        .options {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .option {
            padding: 18px 20px;
            background: #f8f9fa;
            border: 2px solid #e0e0e0;
            border-radius: 14px;
            cursor: pointer;
            font-size: 1.08em;
            transition: all 0.3s;
        }

        .option:hover {
            border-color: #1e88e5;
            background: #e3f2fd;
        }

        .option.selected {
            background: #e8f5e9;
            border-color: #43a047;
            font-weight: 600;
        }

        .navigation {
            display: flex;
            justify-content: space-between;
            margin-top: 30px;
            gap: 12px;
        }

        button {
            flex: 1;
            padding: 16px;
            font-size: 1.1em;
            font-weight: 600;
            border-radius: 12px;
            border: none;
            cursor: pointer;
        }

        #prev-btn {
            background: #f1f5f9;
            color: #555;
            border: 2px solid #ddd;
        }

        #next-btn {
            background: var(--primary);
            color: white;
        }

        .result {
            display: none;
            text-align: center;
            padding: 20px 10px;
        }

        .culture-card {
            background: #f8fafc;
            padding: 30px 20px;
            border-radius: 18px;
            margin: 20px 0;
        }

        .emoji {
            font-size: 4.5em;
            margin-bottom: 15px;
        }

        @media (min-width: 768px) {
            h1 { font-size: 2.6em; }
            .content { padding: 45px 40px; }
            .option { font-size: 1.15em; padding: 22px 24px; }
            .emoji { font-size: 5.8em; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <img src="https://i.postimg.cc/LJc7x94j/logo-utel.png" alt="Logo UTEL" class="logo">
            <h1>¿Qué Cultura Organizacional Eres?</h1>
            <p class="subtitle">Empresas Mexicanas Edition 🇲🇽</p>
        </header>

        <div class="content">
            <div class="progress">
                <div id="progress-bar" class="progress-bar"></div>
            </div>

            <div id="quiz">
                <h2 id="question-text">Pregunta 1 de 5</h2>
                <div class="options" id="options"></div>

                <div class="navigation">
                    <button id="prev-btn" onclick="prevQuestion()">← Anterior</button>
                    <button id="next-btn" onclick="nextQuestion()">Siguiente →</button>
                </div>
            </div>

            <div id="result" class="result">
                <h2>¡Felicidades! Esta es tu cultura:</h2>
                <div id="culture-result" class="culture-card"></div>

                <h3>¿Qué significa esto?</h3>
                <p id="description"></p>

                <h3>Beneficios principales:</h3>
                <ul id="benefits"></ul>

                <h3>Ejemplos de empresas mexicanas:</h3>
                <p id="examples" style="font-weight: bold; color: #c62828; font-size: 1.2em;"></p>

                <button onclick="reiniciarJuego()" style="margin-top: 25px; width: 100%; padding: 18px;">
                    Realizar el test nuevamente
                </button>
            </div>
        </div>
    </div>

    <script>
        const preguntas = [
            { pregunta: "En el trabajo, ¿qué valoras más?", 
              opciones: [
                { texto: "Sentirme parte de una familia y que me apoyen", valor: "familiar" },
                { texto: "Poder proponer ideas nuevas y creativas", valor: "creativa" },
                { texto: "Ganar, competir y obtener buenos resultados", valor: "competitiva" },
                { texto: "Que todo esté bien organizado y con reglas claras", valor: "estructurada" }
            ]},
            { pregunta: "Cuando hay un problema en la empresa, ¿qué prefieres?", 
              opciones: [
                { texto: "Que todos nos reunamos y lo resolvamos juntos como equipo", valor: "familiar" },
                { texto: "Probar soluciones nuevas aunque sean arriesgadas", valor: "creativa" },
                { texto: "Que se tome la decisión que más beneficie las ventas o ganancias", valor: "competitiva" },
                { texto: "Seguir el procedimiento establecido y respetar la cadena de mando", valor: "estructurada" }
            ]},
            { pregunta: "¿Cómo te gustaría que sea tu jefe?", 
              opciones: [
                { texto: "Como un líder cercano, que se preocupe por mí", valor: "familiar" },
                { texto: "Alguien que motive la innovación y las ideas locas", valor: "creativa" },
                { texto: "Alguien exigente que me impulse a dar lo mejor", valor: "competitiva" },
                { texto: "Alguien claro que dé instrucciones precisas y justas", valor: "estructurada" }
            ]},
            { pregunta: "En una empresa ideal, ¿qué es más importante?", 
              opciones: [
                { texto: "La lealtad y el buen ambiente entre compañeros", valor: "familiar" },
                { texto: "La creatividad y adaptarse rápido a los cambios", valor: "creativa" },
                { texto: "Ser mejor que la competencia y crecer constantemente", valor: "competitiva" },
                { texto: "La eficiencia, el orden y el control de procesos", valor: "estructurada" }
            ]},
            { pregunta: "Cuando hay un cambio grande en la empresa, ¿cómo reaccionas?", 
              opciones: [
                { texto: "Me preocupa si afecta al equipo y las relaciones", valor: "familiar" },
                { texto: "¡Me emociona! Es una oportunidad para innovar", valor: "creativa" },
                { texto: "Lo veo como una oportunidad para ganar más mercado", valor: "competitiva" },
                { texto: "Prefiero que se planee bien y se comunique claramente", valor: "estructurada" }
            ]}
        ];

        let respuestas = [];
        let preguntaActual = 0;

        function actualizarProgreso() {
            const porcentaje = ((preguntaActual + 1) / preguntas.length) * 100;
            document.getElementById("progress-bar").style.width = `${porcentaje}%`;
        }

        function mostrarPregunta() {
            document.getElementById("question-text").textContent = `Pregunta ${preguntaActual + 1} de ${preguntas.length}`;

            const optionsDiv = document.getElementById("options");
            optionsDiv.innerHTML = "";

            preguntas[preguntaActual].opciones.forEach((opcion, index) => {
                const div = document.createElement("div");
                div.className = "option";
                div.textContent = opcion.texto;
                div.onclick = () => seleccionarRespuesta(index);
                optionsDiv.appendChild(div);
            });

            actualizarProgreso();
            actualizarBotones();
        }

        function seleccionarRespuesta(index) {
            respuestas[preguntaActual] = preguntas[preguntaActual].opciones[index].valor;
            document.querySelectorAll(".option").forEach((opt, i) => {
                opt.classList.toggle("selected", i === index);
            });
            actualizarBotones();
        }

        function actualizarBotones() {
            document.getElementById("next-btn").style.display = respuestas[preguntaActual] ? "block" : "none";
            document.getElementById("prev-btn").style.display = preguntaActual > 0 ? "block" : "none";
        }

        function nextQuestion() {
            if (respuestas[preguntaActual]) {
                preguntaActual++;
                if (preguntaActual < preguntas.length) {
                    mostrarPregunta();
                } else {
                    mostrarResultado();
                }
            }
        }

        function prevQuestion() {
            if (preguntaActual > 0) {
                preguntaActual--;
                mostrarPregunta();
            }
        }

        function calcularCultura() {
            const conteo = { familiar: 0, creativa: 0, competitiva: 0, estructurada: 0 };
            respuestas.forEach(r => conteo[r]++);
            return Object.keys(conteo).reduce((a, b) => conteo[a] > conteo[b] ? a : b);
        }

        function mostrarResultado() {
            document.getElementById("quiz").style.display = "none";
            const result = document.getElementById("result");
            result.style.display = "block";

            const tipo = calcularCultura();
            let titulo = "", emoji = "", desc = "", beneficios = [], ejemplos = "";

            if (tipo === "familiar") {
                titulo = "Cultura Familiar"; emoji = "👨‍👩‍👧‍👦";
                desc = "Es como trabajar en una gran familia. Se valora la confianza, el apoyo y la lealtad.";
                beneficios = ["Alta motivación", "Baja rotación", "Buen clima laboral"];
                ejemplos = "Grupo Bimbo, FEMSA, Liverpool";
            } else if (tipo === "creativa") {
                titulo = "Cultura Creativa"; emoji = "💡";
                desc = "Ambiente que fomenta la creatividad y la innovación constante.";
                beneficios = ["Alta innovación", "Adaptación rápida", "Ambiente dinámico"];
                ejemplos = "Kavak, Clip, Cinépolis";
            } else if (tipo === "competitiva") {
                titulo = "Cultura Competitiva"; emoji = "🏆";
                desc = "Enfocada en resultados, competencia y alto desempeño.";
                beneficios = ["Crecimiento rápido", "Alta productividad", "Recompensas por metas"];
                ejemplos = "América Móvil, Grupo Salinas";
            } else {
                titulo = "Cultura Estructurada"; emoji = "📋";
                desc = "Procesos claros, orden y estabilidad.";
                beneficios = ["Estabilidad", "Eficiencia", "Roles bien definidos"];
                ejemplos = "Banorte, Cemex";
            }

            document.getElementById("culture-result").innerHTML = `
                <span class="emoji">${emoji}</span>
                <h2>${titulo}</h2>
            `;
            document.getElementById("description").textContent = desc;

            const ul = document.getElementById("benefits");
            ul.innerHTML = "";
            beneficios.forEach(b => {
                const li = document.createElement("li");
                li.textContent = "• " + b;
                ul.appendChild(li);
            });

            document.getElementById("examples").textContent = ejemplos;
        }

        function reiniciarJuego() {
            respuestas = [];
            preguntaActual = 0;
            document.getElementById("quiz").style.display = "block";
            document.getElementById("result").style.display = "none";
            mostrarPregunta();
        }

        window.onload = mostrarPregunta;
    </script>
</body>
</html>
